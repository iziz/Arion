{
  "name": "arion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:cleanup && npm run dev:infra && concurrently --kill-others-on-fail \"npm:dev:api\" \"npm:dev:worker:run\" \"npm:dev:ask-worker:run\" \"npm:dev:web\"",
    "dev:full": "npm run dev:cleanup && npm run dev:infra && concurrently --kill-others-on-fail \"npm:models:runtime:ai\" \"npm:models:vlm:ai\" \"npm:dev:api\" \"npm:dev:worker:run\" \"npm:dev:ask-worker:run\" \"npm:dev:web\"",
    "dev:cleanup": "tsx scripts/dev_process_guard.ts",
    "dev:infra": "tsx scripts/docker_infra.ts up",
    "infra:up": "tsx scripts/docker_infra.ts up",
    "infra:check": "tsx scripts/docker_infra.ts check",
    "infra:down": "tsx scripts/docker_infra.ts down",
    "infra:logs": "docker compose logs -f redis postgres",
    "dev:api": "ARION_DOCKER_INFRA=true tsx watch server/index.ts",
    "dev:worker": "npm run dev:infra && npm run dev:worker:run",
    "dev:worker:run": "ARION_DOCKER_INFRA=true tsx watch server/jobWorker.ts",
    "dev:ask-worker": "npm run dev:infra && npm run dev:ask-worker:run",
    "dev:ask-worker:run": "ARION_DOCKER_INFRA=true tsx watch server/askWorker.ts",
    "dev:web": "tsx scripts/wait_for_dev_api.ts && npm run dev:web:run",
    "dev:web:run": "vite --host 0.0.0.0",
    "api": "tsx server/index.ts",
    "worker": "npm run dev:infra && ARION_DOCKER_INFRA=true npm run worker:run",
    "worker:run": "tsx server/jobWorker.ts",
    "ask-worker": "npm run dev:infra && ARION_DOCKER_INFRA=true npm run ask-worker:run",
    "ask-worker:run": "tsx server/askWorker.ts",
    "build": "tsc --noEmit && vite build",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "db:check": "ARION_DOCKER_INFRA=true tsx scripts/postgres_check.ts",
    "legacy:migrate": "npm run dev:infra && ARION_DOCKER_INFRA=true tsx scripts/migrate_legacy_to_docker.ts --copy-app-data --archive-legacy-stores",
    "video:purge": "npm run dev:infra && ARION_DOCKER_INFRA=true tsx scripts/purge_video_data.ts",
    "docker:migrate:legacy": "npm run legacy:migrate",
    "db:seed": "ARION_DOCKER_INFRA=true tsx scripts/postgres_seed.ts",
    "db:reset": "ARION_DOCKER_INFRA=true tsx scripts/postgres_reset.ts",
    "docker:build": "docker compose --profile app build",
    "docker:up": "docker compose --profile app up --build",
    "docker:full": "docker compose --profile app --profile ai up --build",
    "docker:down": "docker compose --profile app --profile ai down",
    "docker:logs": "docker compose --profile app --profile ai logs -f",
    "knowledge:football-data": "tsx scripts/import_football_data.ts",
    "knowledge:football-data-uk": "tsx scripts/import_football_data_uk.ts",
    "knowledge:nflverse": "tsx scripts/import_nflverse.ts",
    "knowledge:american-football-action-spots": "tsx scripts/build_american_football_action_spots.ts",
    "knowledge:sync-current": "tsx scripts/sync_current_sports_knowledge.ts",
    "knowledge:statsbomb": "tsx scripts/import_statsbomb_open_data.ts",
    "knowledge:statbunker": "tsx scripts/import_statbunker.ts",
    "knowledge:vectors:rebuild": "tsx scripts/rebuild_knowledge_vectors.ts",
    "embeddings:rebuild": "tsx scripts/rebuild_embeddings.ts",
    "indexes:rebuild": "tsx scripts/rebuild_all_indexes.ts",
    "domain:vlm:refine": "tsx scripts/refine_vlm_domain.ts",
    "text:repair": "tsx scripts/repair_text_encoding.ts",
    "models:doctor": "python3 scripts/model_doctor.py",
    "models:doctor:ai": "./.venv-ai/bin/python scripts/model_doctor.py",
    "models:runtime": "python3 scripts/arion_model_runtime_service.py",
    "models:runtime:ai": "./.venv-ai/bin/python scripts/arion_model_runtime_service.py",
    "models:vlm": "python3 scripts/qwen_vlm_worker.py",
    "models:vlm:ai": "./.venv-ai/bin/python scripts/qwen_vlm_worker.py",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@vitejs/plugin-react": "^5.0.4",
    "bullmq": "^5.76.5",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "pg": "^8.20.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.20.6",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.6.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.2"
  }
}

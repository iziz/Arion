LOCAL_AI_PYTHON="/absolute/path/to/project/.venv-ai/bin/python"
ARION_PROCESS_ROLE=
ALLOW_API_MODEL_RUNTIME=false
PYTHON_RUNTIME_MODE=service
PYTHON_RUNTIME_SERVICE_URL=http://127.0.0.1:8792
PYTHON_RUNTIME_SERVICE_HOST=127.0.0.1
PYTHON_RUNTIME_SERVICE_PORT=8792
PYTHON_RUNTIME_SERVICE_TIMEOUT_MS=
PYTHON_RUNTIME_SERVICE_ATTEMPTS=2
ASR_RUNTIME_MODE=
ASR_RUNTIME_SERVICE_URL=
OCR_RUNTIME_MODE=
OCR_RUNTIME_SERVICE_URL=
VISION_RUNTIME_MODE=
VISION_RUNTIME_SERVICE_URL=
EMBEDDING_RUNTIME_MODE=
EMBEDDING_RUNTIME_SERVICE_URL=
LOCAL_OBJECT_PROVIDER=local-s3
MEDIA_SERVING_MODE=local-static
MEDIA_STATIC_MAX_AGE=1h
UPLOAD_MAX_BYTES=8589934592
UPLOAD_TEMP_MAX_AGE_MS=86400000
WHISPER_MODEL=large-v3
WHISPER_BACKEND=auto
WHISPER_CPP_BIN=
WHISPER_CPP_MODEL=
WHISPER_CPP_THREADS=
WHISPER_CPP_EXTRA_ARGS=
WHISPERX_MODEL=large-v3
WHISPER_LANGUAGE=auto
WHISPER_TIMEOUT_MS=
WHISPER_TIMEOUT_REALTIME_FACTOR=1.2
WHISPER_CPU_THREADS=
WHISPER_NUM_WORKERS=
WHISPERX_HF_TOKEN=
WHISPERX_TIMEOUT_MS=
WHISPERX_CPU_THREADS=
LOCAL_MODEL_RUNTIME_HEAVY_CONCURRENCY=2
PADDLEOCR_LANG=auto
PADDLEOCR_SUBTITLE_INTERVAL_SECONDS=0.5
PADDLEOCR_SUBTITLE_MAX_FRAMES=1800
PADDLEOCR_FULL_MAX_FRAMES=24
PADDLEOCR_FRAME_WIDTH=960
PADDLEOCR_TIMEOUT_MS=
PADDLEOCR_DEDUPE_THRESHOLD=3.0
PADDLEOCR_WORKERS=2
PADDLEOCR_LANGUAGE_CONCURRENCY=
PADDLEOCR_CPU_THREADS_PER_WORKER=
VISION_DETECTOR_BACKEND=auto
VISION_DETECTOR_MODEL=yolo11n.pt
VISION_DETECTOR_CONF=0.25
VISION_RFDETR_MODEL=RFDETRNano
VISION_RFDETR_WEIGHTS=
VISION_ALLOW_OPENCV_HEURISTIC=false
VISION_TRACKER=bytetrack.yaml
VISION_TRACKER_CONF=0.2
VISION_TRACKER_VID_STRIDE=3
SOCCERNET_ACTION_SPOTTING_ENABLED=false
SOCCERNET_ACTION_SPOTTING_MODEL=external
SOCCERNET_ACTION_SPOTTING_COMMAND=
SOCCERNET_ACTION_SPOTS_JSON=
SOCCERNET_ACTION_SPOT_TOLERANCE_SECONDS=3
CAPABILITY_WHISPERX_DIARIZATION=optional
CAPABILITY_VISION_DETECTOR=optional
CAPABILITY_VISION_TRACKER=optional
CAPABILITY_SOCCERNET_ACTION_SPOTTING=optional
CAPABILITY_DOMAIN_VLM_REFINEMENT=optional
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIMENSIONS=768
EMBEDDING_TIMEOUT_MS=
VISUAL_EMBEDDING_MODEL=ViT-B-32
VISUAL_EMBEDDING_PRETRAINED=laion2b_s34b_b79k
VISUAL_EMBEDDING_DIMENSIONS=512
VISUAL_EMBEDDING_TIMEOUT_MS=
VLM_WORKER_URL=http://127.0.0.1:8791
VLM_WORKER_MODEL=mlx-community/Qwen2.5-VL-7B-Instruct-4bit
VLM_WORKER_TIMEOUT_MS=90000
TIMELINE_MAX_SEGMENTS=120
QWEN_VLM_BACKEND=mlx
QWEN_VLM_MODEL=mlx-community/Qwen2.5-VL-7B-Instruct-4bit
QWEN_VLM_TRANSFORMERS_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_VLM_MLX_MODEL=mlx-community/Qwen2.5-VL-7B-Instruct-4bit
QWEN_VLM_DEVICE_MAP=mps
QWEN_VLM_TORCH_DTYPE=float32
QWEN_VLM_HOST=127.0.0.1
QWEN_VLM_PORT=8791
QWEN_VLM_MAX_NEW_TOKENS=384
SCENE_TIMEOUT_MS=
CONSOLE_LOG_LEVEL=important

# Enable PostgreSQL + pgvector storage by setting DATABASE_URL.
# Without this value, the app uses .data/db.json and .data/vector-store.json.
DATABASE_URL=postgres://video_intelligence:video_intelligence@localhost:5432/video_intelligence
POSTGRES_APPLICATION_NAME=arion
POSTGRES_POOL_MAX=10
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_REQUIRE_PGVECTOR=false
PGSSLMODE=disable

# Redis is required for asset job and ask operation execution.
REDIS_URL=redis://127.0.0.1:6379
JOB_QUEUE_NAME=arion:asset-jobs
JOB_WORKER_CONCURRENCY=1
JOB_QUEUE_RECONCILE_MS=15000
ASK_QUEUE_NAME=arion:ask-operations
ASK_WORKER_CONCURRENCY=2
ASK_QUEUE_RECONCILE_MS=15000

LOCAL_AI_PYTHON="/absolute/path/to/project/.venv-ai/bin/python"
LOCAL_OBJECT_PROVIDER=local-s3
WHISPER_MODEL=large-v3
WHISPERX_MODEL=large-v3
WHISPER_LANGUAGE=auto
WHISPER_TIMEOUT_MS=
WHISPER_TIMEOUT_REALTIME_FACTOR=1.2
WHISPERX_HF_TOKEN=
WHISPERX_TIMEOUT_MS=
PADDLEOCR_LANG=auto
PADDLEOCR_SUBTITLE_INTERVAL_SECONDS=0.5
PADDLEOCR_SUBTITLE_MAX_FRAMES=1800
PADDLEOCR_FULL_MAX_FRAMES=24
PADDLEOCR_FRAME_WIDTH=960
PADDLEOCR_TIMEOUT_MS=
PADDLEOCR_DEDUPE_THRESHOLD=3.0
PADDLEOCR_WORKERS=2
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSIONS=384
EMBEDDING_TIMEOUT_MS=
VISUAL_EMBEDDING_MODEL=ViT-B-32
VISUAL_EMBEDDING_PRETRAINED=laion2b_s34b_b79k
VISUAL_EMBEDDING_DIMENSIONS=512
VISUAL_EMBEDDING_TIMEOUT_MS=
SCENE_TIMEOUT_MS=
CONSOLE_LOG_LEVEL=important

# Enable PostgreSQL + pgvector storage by setting DATABASE_URL.
# Without this value, the app uses .data/db.json and .data/vector-store.json.
DATABASE_URL=postgres://video_intelligence:video_intelligence@localhost:5432/video_intelligence

NODE_ENV=production
CONSOLE_LOG_LEVEL=important

PORT=8787
DATABASE_URL=postgres://video_intelligence:video_intelligence@postgres:5432/video_intelligence
POSTGRES_APPLICATION_NAME=arion
POSTGRES_POOL_MAX=10
POSTGRES_CONNECTION_TIMEOUT_MS=5000
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_REQUIRE_PGVECTOR=true
PGSSLMODE=disable

REDIS_URL=redis://redis:6379
JOB_QUEUE_NAME=arion-asset-jobs
JOB_WORKER_CONCURRENCY=1
JOB_QUEUE_RECONCILE_MS=15000
JOB_WORKER_LOCK_DURATION_MS=600000
JOB_WORKER_STALLED_INTERVAL_MS=60000
ASK_QUEUE_NAME=arion-ask-operations
ASK_WORKER_CONCURRENCY=2
ASK_QUEUE_RECONCILE_MS=15000

ALLOW_API_MODEL_RUNTIME=false
PYTHON_RUNTIME_MODE=service
PYTHON_RUNTIME_SERVICE_URL=http://model-runtime:8792
PYTHON_RUNTIME_SERVICE_HOST=0.0.0.0
PYTHON_RUNTIME_SERVICE_PORT=8792
PYTHON_RUNTIME_SERVICE_ATTEMPTS=2

LOCAL_OBJECT_PROVIDER=local-s3
MEDIA_SERVING_MODE=local-static
MEDIA_STATIC_MAX_AGE=1h
UPLOAD_MAX_BYTES=8589934592
UPLOAD_TEMP_MAX_AGE_MS=86400000

VLM_WORKER_URL=http://vlm:8791
VLM_WORKER_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_VLM_BACKEND=transformers
QWEN_VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_VLM_TRANSFORMERS_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_VLM_HOST=0.0.0.0
QWEN_VLM_PORT=8791
QWEN_VLM_DEVICE_MAP=auto
QWEN_VLM_TORCH_DTYPE=auto
QWEN_VLM_MAX_NEW_TOKENS=384

WHISPER_MODEL=large-v3
WHISPER_BACKEND=auto
WHISPER_LANGUAGE=auto
WHISPERX_MODEL=large-v3
PADDLEOCR_LANG=auto
PADDLEOCR_SUBTITLE_INTERVAL_SECONDS=0.5
PADDLEOCR_SUBTITLE_MAX_FRAMES=1800
PADDLEOCR_FULL_MAX_FRAMES=24
PADDLEOCR_FRAME_WIDTH=960
PADDLEOCR_DEDUPE_THRESHOLD=3.0
PADDLEOCR_WORKERS=2
VISION_DETECTOR_BACKEND=auto
VISION_DETECTOR_MODEL=yolo11n.pt
VISION_DETECTOR_CONF=0.25
VISION_TRACKER=bytetrack.yaml
VISION_TRACKER_CONF=0.2
VISION_TRACKER_VID_STRIDE=3
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIMENSIONS=768
VISUAL_EMBEDDING_MODEL=ViT-B-32
VISUAL_EMBEDDING_PRETRAINED=laion2b_s34b_b79k
VISUAL_EMBEDDING_DIMENSIONS=512
